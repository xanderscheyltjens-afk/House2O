    "    cache    = set(zip(cache_df[\"angle\"], cache_df[\"date\"], cache_df[\"hour\"])) # retrieves unique new computation request such that what's already in the csv doesn't get computed again\n",
    "    records  = cache_df.to_dict(\"records\") # these are the already completed computations\n",
